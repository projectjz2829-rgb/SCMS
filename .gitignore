# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─── Flask / SQLite ───────────────────────────────────────────────────────────
instance/
*.db
*.sqlite3

# ─── Environment secrets — NEVER commit ──────────────────────────────────────
.env
.env.*
# Keep the example template committed
!.env.example

# ─── Application logs ────────────────────────────────────────────────────────
logs/
*.log

# ─── Migration versions — commit these so Render can run flask db upgrade ────
# (remove this block only if you want to commit migration scripts)
# migrations/versions/

# ─── Test & coverage artefacts ───────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ─── Build / packaging ───────────────────────────────────────────────────────
node_modules/
dist/
build/
*.egg-info/
*.egg
.eggs/
!backend/app/static/dist

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig
