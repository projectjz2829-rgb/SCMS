# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─── Flask / SQLite ───────────────────────────────────────────────────────────
instance/
*.db
*.sqlite
*.sqlite3

# ─── Environment secrets — NEVER commit ──────────────────────────────────────
.env
.env.*
!.env.example

# ─── Application logs ────────────────────────────────────────────────────────
logs/
*.log

# ─── Test & coverage artefacts ───────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage/
coverage.xml

# ─── Build / packaging ───────────────────────────────────────────────────────
node_modules/
dist/
build/
*.egg-info/
*.egg
.eggs/

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig

# ─── Temporary / Agent Artifacts ──────────────────────────────────────────────
tmp/
temp/
.cache/
scratch/
checkpoints/
