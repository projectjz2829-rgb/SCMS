# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─── Flask / SQLite ───────────────────────────────────────────────────────────
instance/
*.db
*.sqlite
*.sqlite3

# ─── Environment secrets — NEVER commit ──────────────────────────────────────
.env
.env.*
!.env.example

# ─── Application logs ────────────────────────────────────────────────────────
logs/
*.log

# ─── Test & coverage artefacts ───────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage/
coverage.xml

# ─── Build / packaging ───────────────────────────────────────────────────────
node_modules/
frontend/dist/
build/
*.egg-info/
*.egg
.eggs/

# ─── Frontend build output (generated by Vite — always rebuilt on Render) ────
# (Removed ignore rule because Render env: python cannot run npm build, so assets MUST be committed)
# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig

# ─── Temporary / Agent Artifacts ──────────────────────────────────────────────
tmp/
temp/
.cache/
scratch/
checkpoints/
generated_reports/
browser_traces/
AI_reports/
