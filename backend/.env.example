# ─────────────────────────────────────────────────────────────────────────────
#  SCMS — Environment Variable Template
#  Copy this file to .env and fill in real values.
#  NEVER commit the actual .env file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Flask environment: "development" | "production"
FLASK_ENV=production

# A long, random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_64_CHAR_RANDOM_HEX_STRING

# Database — SQLite for local dev, PostgreSQL for Render
# Local SQLite example:
# DATABASE_URL=sqlite:///instance/campus.db
# Render PostgreSQL (copied from Render dashboard → PostgreSQL → Connection String):
DATABASE_URL=postgresql://user:password@host:5432/campus_db

# Admin account seeding
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Security — set True in production (HTTPS required), False for local HTTP dev
SESSION_COOKIE_SECURE=True

# CSRF — always True in production
WTF_CSRF_ENABLED=True

# Debug — MUST be 0 in production
FLASK_DEBUG=0
